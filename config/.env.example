# Service Configuration
SERVICE_NAME=naxis
LOG_LEVEL=INFO
ENVIRONMENT=development

# Storage backend: memory (default, no Docker required) | postgres (persistent)
STORAGE_MODE=memory

# API Gateway
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=naxis
POSTGRES_PASSWORD=naxis_dev
POSTGRES_DATABASE=naxis

# Redis Configuration (used only for real-time notifications)
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=10
REDIS_ENABLED=false

# Ollama Configuration
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TEMPERATURE=0.7
OLLAMA_MAX_TOKENS=2000

# Collector Configuration
COLLECTOR_INTERVAL=60

# Cisco DNAC
DNAC_HOST=
DNAC_USERNAME=
DNAC_PASSWORD=
DNAC_VERIFY_SSL=false

# Juniper Mist
MIST_API_KEY=
MIST_ORG_ID=
MIST_BASE_URL=https://api.mist.com

# Arista SD-WAN
ARISTA_SDWAN_HOST=
ARISTA_SDWAN_API_KEY=
ARISTA_SDWAN_VERIFY_SSL=false

# Arista WLC
ARISTA_WLC_HOST=
ARISTA_WLC_USERNAME=
ARISTA_WLC_PASSWORD=
ARISTA_WLC_VERIFY_SSL=false

# Correlation Configuration
CORRELATION_TIME_WINDOW=300
CORRELATION_PROXIMITY_HOPS=2
CORRELATION_MIN_EVENTS=2

# Data Retention
EVENT_RETENTION_DAYS=90
INCIDENT_RETENTION_DAYS=180
STREAM_RETENTION_HOURS=168

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
