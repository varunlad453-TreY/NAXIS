# Service Configuration
SERVICE_NAME=naxis
LOG_LEVEL=INFO
ENVIRONMENT=development

# API Gateway
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Redis Configuration
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=10

# ClickHouse Configuration
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=naxis

# Neo4j Configuration
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=naxis_password

# Ollama Configuration
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TEMPERATURE=0.7
OLLAMA_MAX_TOKENS=2000

# Collector Configuration
COLLECTOR_INTERVAL=60

# Cisco DNAC
DNAC_HOST=
DNAC_USERNAME=
DNAC_PASSWORD=
DNAC_VERIFY_SSL=false

# Juniper Mist
MIST_API_KEY=
MIST_ORG_ID=
MIST_BASE_URL=https://api.mist.com

# Arista SD-WAN
ARISTA_SDWAN_HOST=
ARISTA_SDWAN_API_KEY=
ARISTA_SDWAN_VERIFY_SSL=false

# Arista WLC
ARISTA_WLC_HOST=
ARISTA_WLC_USERNAME=
ARISTA_WLC_PASSWORD=
ARISTA_WLC_VERIFY_SSL=false

# Correlation Configuration
CORRELATION_TIME_WINDOW=300
CORRELATION_PROXIMITY_HOPS=2
CORRELATION_MIN_EVENTS=2

# Data Retention
EVENT_RETENTION_DAYS=90
INCIDENT_RETENTION_DAYS=180
STREAM_RETENTION_HOURS=168

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
